{
  "$schema": "https://opencode.ai/config.json",

  "agent": {
    "build": {
      "mode": "primary",
      // "model": "zai-coding-plan/glm-4.7"
      // "model": "deepseek/deepseek-chat"
      "model": "minimax-coding-plan/MiniMax-M2.7"
    },
    "plan": {
      "mode": "primary",
      // "model": "zai-coding-plan/glm-4.7"
      // "model": "deepseek/deepseek-chat"
      "model": "minimax-coding-plan/MiniMax-M2.7"
    }
  },

  "mcp": {
    "agentmux": {
      "type": "local",
      "command": [
        "agentmux",
        "host",
        "mcp",
        "--bundle",
        "python-foundation"
      ],
      "enabled": true,
      "timeout": 900000
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "nb": {
      "type": "local",
      "command": [
        "nb-mcp",
        "--notebook",
        "python-classcore",
        "--no-commit-signing"
      ],
      "enabled": true
    }
  },

  "permission": {
    "bash": {
      "*": "ask",
      "hatch run *": "allow",
      "hatch --env develop run *": "allow",
      "awk *": "allow",
      "cat *": "allow",
      "cut *": "allow",
      "df *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "file *": "allow",
      "find *": "allow",
      "gh browse *": "allow",
      "gh issue list *": "allow",
      "gh issue view *": "allow",
      "gh pr checks *": "allow",
      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh release list *": "allow",
      "gh release view *": "allow",
      "gh repo list *": "allow",
      "gh repo view *": "allow",
      "gh run list *": "allow",
      "gh run view *": "allow",
      "gh run watch *": "allow",
      "gh search issues *": "allow",
      "gh status *": "allow",
      "git add *": "allow",
      "git branch *": "allow",
      "git checkout *": "allow",
      "git diff *": "allow",
      "git fetch *": "allow",
      "git log *": "allow",
      "git rebase *": "allow",
      "git restore *": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git stash list": "allow",
      "git stash list *": "allow",
      "git status *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "ps *": "allow",
      "pwd *": "allow",
      "rg *": "allow",
      "sed *": "allow",
      "sort *": "allow",
      "tail *": "allow",
      "uniq *": "allow",
      "wc *": "allow",
      "which *": "allow"
    },
    "edit": "allow",
    "webfetch": "ask"
  },

  "formatter": {
    "ruff": {
      "disabled": true
    },
    "prettier": {
      "disabled": true
    }
  },

  "lsp": {
    "pyright": {
      "disabled": true
    }
  }
}
